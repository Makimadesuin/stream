<!DOCTYPE html>
<html lang="id" class="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= video.title %> - StreamKu</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>tailwind.config={darkMode:'class',theme:{extend:{colors:{dark:{900:'#0f0f0f',800:'#1a1a1a',700:'#272727',600:'#3a3a3a'}}}}}</script>
</head>
<body class="bg-dark-900 text-gray-100 min-h-screen">
  <header class="bg-dark-800 border-b border-dark-600 px-6 py-4">
    <a href="/" class="text-xl font-bold tracking-tight">Stream<span class="text-red-500">Ku</span></a>
  </header>
  <main class="max-w-5xl mx-auto px-4 py-6">
    <div class="w-full aspect-video rounded-xl overflow-hidden shadow-lg border border-gray-800 bg-black">
      <iframe src="<%= video.video_url %>" class="w-full h-full border-0" allow="autoplay; encrypted-media" allowfullscreen></iframe>
    </div>
    <div class="mt-6">
      <h1 class="text-2xl md:text-3xl font-bold"><%= video.title %></h1>
      <div class="mt-4 bg-dark-800 rounded-xl p-5 border border-dark-600">
        <h2 class="text-sm font-semibold text-gray-400 uppercase tracking-wide mb-2">Deskripsi</h2>
        <p class="text-gray-300 leading-relaxed whitespace-pre-wrap"><%= video.description || 'Tidak ada deskripsi' %></p>
      </div>
      <p class="text-gray-600 text-sm mt-3">Diunggah <%= new Date(video.created_at).toLocaleDateString('id-ID', {year:'numeric',month:'long',day:'numeric'}) %></p>
    </div>
    <a href="/" class="inline-block mt-6 text-sm text-red-400 hover:underline">&larr; Kembali</a>
  </main>
</body>
</html>
