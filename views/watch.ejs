<!DOCTYPE html>
<html lang="id" class="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= video.title %> - StreamKu</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>tailwind.config={darkMode:'class',theme:{extend:{colors:{dark:{900:'#0f0f0f',800:'#1a1a1a',700:'#272727',600:'#3a3a3a'}}}}}</script>
</head>
<body class="bg-dark-900 text-gray-100 min-h-screen">
  <header class="bg-dark-800 border-b border-dark-600 px-6 py-4">
    <a href="/" class="text-xl font-bold tracking-tight">Stream<span class="text-red-500">Ku</span></a>
  </header>
  <main class="max-w-5xl mx-auto px-4 py-6">
    <div class="w-full aspect-video rounded-xl overflow-hidden shadow-lg border border-gray-800 bg-black">
      <iframe src="<%= video.video_url %>" class="w-full h-full border-0" allow="autoplay; encrypted-media" allowfullscreen></iframe>
    </div>
    <div class="mt-6">
      <h1 class="text-2xl md:text-3xl font-bold"><%= video.title %></h1>
      <div class="mt-4 bg-dark-800 rounded-xl p-5 border border-dark-600">
        <h2 class="text-sm font-semibold text-gray-400 uppercase tracking-wide mb-2">Deskripsi</h2>
        <p class="text-gray-300 leading-relaxed whitespace-pre-wrap"><%= video.description || 'Tidak ada deskripsi' %></p>
      </div>
      <p class="text-gray-600 text-sm mt-3">Diunggah <%= new Date(video.created_at).toLocaleDateString('id-ID', {year:'numeric',month:'long',day:'numeric'}) %></p>
    </div>
    <% if (recommendedVideos && recommendedVideos.length > 0) { %>
      <div class="mt-10" id="recommended-section" data-current-id="<%= video.id %>">
        <h2 class="text-xl font-bold mb-4">Rekomendasi Video Lain</h2>
        <div id="recommended-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          <% recommendedVideos.forEach(r => { %>
            <a href="/watch/<%= r.id %>" data-id="<%= r.id %>" class="group bg-dark-800 rounded-xl overflow-hidden border border-dark-600 hover:border-red-500/50 transition-all duration-200">
              <div class="aspect-video bg-dark-700 overflow-hidden">
                <% if (r.thumbnail_url) { %>
                  <img src="<%= r.thumbnail_url %>" alt="<%= r.title %>" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-200">
                <% } else { %>
                  <div class="w-full h-full flex items-center justify-center text-gray-500">No Thumbnail</div>
                <% } %>
              </div>
              <div class="p-3">
                <h3 class="font-semibold text-sm group-hover:text-red-400 transition-colors line-clamp-2"><%= r.title %></h3>
              </div>
            </a>
          <% }) %>
        </div>
        <button id="show-more-btn" class="mt-4 w-full py-2.5 px-4 rounded-lg bg-dark-700 hover:bg-dark-600 border border-dark-600 text-sm text-gray-300 hover:text-white transition-all duration-200 cursor-pointer disabled:opacity-50 disabled:cursor-not-allowed">Show More</button>
      </div>
    <% } %>
    <a href="/" class="inline-block mt-6 text-sm text-red-400 hover:underline">&larr; Kembali</a>
  </main>
  <script>
    document.addEventListener('DOMContentLoaded', function() {
      var grid = document.getElementById('recommended-grid');
      var btn = document.getElementById('show-more-btn');
      var section = document.getElementById('recommended-section');
      if (!grid || !btn || !section) return;

      btn.addEventListener('click', async function() {
        var cards = grid.querySelectorAll('[data-id]');
        var ids = Array.from(cards).map(function(c) { return c.dataset.id; });
        var currentId = section.dataset.currentId;
        if (currentId) ids.push(currentId);
        var exclude = ids.join(',');

        btn.disabled = true;
        btn.textContent = 'Memuat...';

        try {
          var res = await fetch('/api/more-videos?exclude=' + encodeURIComponent(exclude));
          var data = await res.json();

          if (data.videos && data.videos.length > 0) {
            data.videos.forEach(function(v) {
              var card = document.createElement('a');
              card.href = '/watch/' + v.id;
              card.setAttribute('data-id', v.id);
              card.className = 'group bg-dark-800 rounded-xl overflow-hidden border border-dark-600 hover:border-red-500/50 transition-all duration-200';

              var thumbnailHtml;
              if (v.thumbnail_url) {
                thumbnailHtml = '<img src="' + v.thumbnail_url + '" alt="' + v.title.replace(/"/g, '&quot;') + '" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-200">';
              } else {
                thumbnailHtml = '<div class="w-full h-full flex items-center justify-center text-gray-500">No Thumbnail</div>';
              }

              card.innerHTML = '<div class="aspect-video bg-dark-700 overflow-hidden">' + thumbnailHtml + '</div>' +
                '<div class="p-3"><h3 class="font-semibold text-sm group-hover:text-red-400 transition-colors line-clamp-2">' + v.title + '</h3></div>';

              grid.appendChild(card);
            });
          }

          if (!data.videos || data.videos.length < 5) {
            btn.textContent = 'Semua video sudah ditampilkan';
            btn.disabled = true;
          } else {
            btn.disabled = false;
            btn.textContent = 'Show More';
          }
        } catch (err) {
          console.error(err);
          btn.textContent = 'Gagal memuat, coba lagi';
          btn.disabled = false;
        }
      });
    });
  </script>
</body>
</html>
