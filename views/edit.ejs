<!DOCTYPE html>
<html lang="id" class="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Edit Video - StreamKu</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>tailwind.config={darkMode:'class',theme:{extend:{colors:{dark:{900:'#0f0f0f',800:'#1a1a1a',700:'#272727',600:'#3a3a3a'}}}}}</script>
</head>
<body class="bg-[#0a0a0a] text-gray-100 min-h-screen">
  <header class="bg-[#0a0a0a]/80 backdrop-blur-md border-b border-white/10 px-6 py-4">
    <a href="/?admin=true" class="text-xl font-bold tracking-tight">Stream<span class="text-emerald-400">Ku</span></a>
  </header>
  <main class="max-w-2xl mx-auto px-4 py-10">
    <h1 class="text-2xl font-bold mb-8">Edit Video</h1>

    <% if (error) { %>
      <div class="bg-red-900/50 border border-red-700 text-red-300 px-5 py-3 rounded-xl mb-6"><%= error %></div>
    <% } %>
    <% if (success) { %>
      <div class="bg-green-900/50 border border-green-700 text-green-300 px-5 py-3 rounded-xl mb-6"><%= success %></div>
    <% } %>

    <form action="/admin/edit/<%= video.id %>" method="POST" class="space-y-6">
      <div>
        <label class="block text-sm font-medium text-gray-400 mb-2">Judul Video</label>
        <input type="text" name="title" value="<%= video.title %>" required
          class="w-full bg-white/5 border border-white/10 rounded-xl px-5 py-3 text-gray-100 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-transparent placeholder-gray-600">
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-400 mb-2">Deskripsi</label>
        <textarea name="description" rows="4"
          class="w-full bg-white/5 border border-white/10 rounded-xl px-5 py-3 text-gray-100 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-transparent placeholder-gray-600 resize-none"><%= video.description %></textarea>
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-400 mb-2">Link Google Drive</label>
        <input type="url" name="video_url" value="<%= video.video_url %>" required
          class="w-full bg-white/5 border border-white/10 rounded-xl px-5 py-3 text-gray-100 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-transparent placeholder-gray-600">
        <p class="text-gray-600 text-xs mt-2">Tempel link baru atau edit yang sudah ada</p>
      </div>
      <button type="submit"
        class="w-full bg-emerald-600 hover:bg-emerald-500 text-white font-semibold py-3 rounded-xl transition">Simpan Perubahan</button>
    </form>
  </main>
</body>
</html>
